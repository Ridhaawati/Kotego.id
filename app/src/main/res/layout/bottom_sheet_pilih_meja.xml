<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="20dp"
    android:background="@drawable/bg_bottom_sheet">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Nomor Meja :"
        android:textSize="20sp"
        android:textStyle="bold"
        android:textColor="@color/black"
        android:gravity="center"
        android:layout_marginBottom="20dp"/>

    <!-- Grid untuk nomor meja -->
    <GridLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:columnCount="3"
        android:rowCount="2"
        android:alignmentMode="alignMargins"
        android:layout_marginBottom="20dp">

        <!-- Meja 1-6 -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator1"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja1"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="1"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator2"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja2"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator3"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja3"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="3"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

        <!-- Baris kedua -->
        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator4"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja4"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="4"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator5"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_green"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja5"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="5"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

        <LinearLayout
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_columnWeight="1"
            android:gravity="center"
            android:orientation="horizontal"
            android:padding="10dp">
            <View
                android:id="@+id/indicator6"
                android:layout_width="12dp"
                android:layout_height="12dp"
                android:background="@drawable/circle_red"
                android:layout_marginEnd="8dp"/>
            <TextView
                android:id="@+id/btnMeja6"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="6"
                android:textSize="18sp"
                android:textColor="@color/black"
                android:clickable="true"
                android:focusable="true"
                android:padding="10dp"/>
        </LinearLayout>

    </GridLayout>

    <!-- Keterangan -->
    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Catatan :\nWarna hijau artinya sudah terisi\nWarna merah belum terisi"
        android:textSize="12sp"
        android:textColor="@color/black"
        android:lineSpacingExtra="4dp"/>

</LinearLayout>